{
  "expo": {
    "name": "Grimoire",
    "slug": "grimoire",
    "version": "1.7.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "grimoire",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.grimoirettrpg.app",
      "appleTeamId": "JQS67937W6",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Grimoire uses your photo library to add images to entities and campaigns.",
        "NSCameraUsageDescription": "Grimoire uses your camera to capture entity and campaign images."
      }
    },
    "android": {
      "package": "com.grimoirettrpg.app",
      "adaptiveIcon": {
        "backgroundColor": "#F2E8D5"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#F2E8D5"
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Grimoire uses your photo library to add images to entities and campaigns.",
          "cameraPermission": "Grimoire uses your camera to capture entity and campaign images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b8d058b5-2dc8-41c0-a9d0-f6ee58464acd"
      }
    },
    "owner": "marcusverus7"
  }
}
